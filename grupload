def html2text(html):
    with NamedTemporaryFile() as tempfile:
        tempfile.write(html)
        tempfile.flush()
        cmd = ['html2text', 'file:///{}'.format(tempfile.name)]
        p = Popen(cmd, stdout=PIPE)
        out, _ = p.communicate()
        assert p.returncode == 0
        return out


