GR_ASIN_TO_ID_URL = 'https://www.goodreads.com/book/isbn_to_id'


class Book(object):

    def __init__(self, post):
        self._post = post
        match = AWS_LINK_RE.match(post['post_content'])
        self.asin = match.group('asin')
        self.review = match.group('review')

    def get_goodreads_id(self):
        response = get(GR_ASIN_TO_ID_URL,
                       params={'key': GR_KEY, 'isbn': self.asin})
        return response.text

    def get_review_text(self):
        return html2text(self.review)


def html2text(html):
    with NamedTemporaryFile() as tempfile:
        tempfile.write(html)
        tempfile.flush()
        cmd = ['html2text', 'file:///{}'.format(tempfile.name)]
        p = Popen(cmd, stdout=PIPE)
        out, = p.communicate()
        assert p.returncode == 0
        return out


def get_books():
